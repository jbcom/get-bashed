" @file vimrc
" @brief get-bashed minimal vimrc.
" @description
"     Minimal defaults used when not installing amix/vimrc.

set nocompatible
set number
set ruler
set showcmd
set hidden
set nowrap
set tabstop=4
set shiftwidth=2
set expandtab
set smartindent
set ignorecase
set smartcase
set incsearch
set hlsearch
set backspace=indent,eol,start
syntax on
